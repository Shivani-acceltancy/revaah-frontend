# --- Option A: Backend on 8081, UI on 8080 (use when API runs on 8081) ---
VITE_DEV_PORT=8080
VITE_API_PROXY_TARGET=http://localhost:8081

# --- Option B (recommended): Backend on 8080, UI on 5173 ---
# Stop the frontend first, then run backend on 8080:
# VITE_DEV_PORT=5173
# VITE_API_PROXY_TARGET=http://localhost:8080

# API calls: empty = use Vite proxy (/v1 → VITE_API_PROXY_TARGET)
VITE_API_BASE_URL=

# Direct to backend (bypass proxy):
# VITE_API_BASE_URL=http://localhost:8081/v1
